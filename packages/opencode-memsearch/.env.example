# Memsearch Plugin Environment Configuration
# Copy this file to .env and fill in your values

# Milvus Connection
# Use localhost for local Milvus (docker-compose up)
# Or your remote Milvus instance
MILVUS_URI=http://localhost:19530

# Ollama Connection (for local embeddings)
# Use localhost:11434 for local Ollama
# Or your remote Ollama instance
OLLAMA_HOST=http://localhost:11434

# Embedding Configuration
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma
VECTOR_DIM=768

# OpenAI Configuration (optional - only if using OpenAI embeddings)
# OPENAI_API_KEY=your_openai_api_key_here

# Test Configuration
TEST_COLLECTION=memsearch_test


# Bunqueue Configuration

# Number of concurrent jobs to process (default: 1)
MEMSEARCH_CONCURRENCY=1

# Queue data directory (default: ~/.config/opencode/memsearch/queue)
MEMSEARCH_QUEUE_PATH=~/.config/opencode/memsearch/queue

# Deduplication TTL in milliseconds (default: 60000 = 1 minute)
MEMSEARCH_DEDUP_TTL=60000

# Delay before retrying deferred jobs in milliseconds (default: 10000 = 10 seconds)
MEMSEARCH_DEFER_DELAY=10000
